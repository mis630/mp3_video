{
  "manifest_version": 3,
  "name": "Smart Video & MP3 Downloader",
  "version": "1.0.0",
  "description": "Download videos and convert to MP3 directly in your browser without servers. 100% client-side processing.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "Smart Video & MP3 Downloader"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/*", "scripts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
